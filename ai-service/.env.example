# ==========================================
# AI Service Environment Variables
# ==========================================

# ------------------------------------------
# Application Information
# ------------------------------------------
# Description: Name of the application
# Required: Optional (Defaults to "InfoLand AI Service")
# Format: String
APP_NAME=InfoLand AI Service

# Description: Version of the application
# Required: Optional (Defaults to "1.0.0")
# Format: String
APP_VERSION=1.0.0

# ------------------------------------------
# Development & Logging
# ------------------------------------------
# Description: Enable debug mode
# Required: Optional (Defaults to False)
# Format: Boolean (True/False)
DEBUG=False

# Description: Logging level
# Required: Optional (Defaults to "INFO")
# Format: String (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ------------------------------------------
# Data Source Paths
# ------------------------------------------
# Description: Path to release data
# Required: Optional (Defaults to "../release")
# Format: Directory path
RELEASE_PATH=../release

# Description: Path to the dataset engine
# Required: Optional (Defaults to "../../infoland-dataset-engine")
# Format: Directory path
DATASET_ENGINE_PATH=../../infoland-dataset-engine

# Description: Base URL for the backend API
# Required: Optional (Defaults to "http://localhost:5000/api")
# Format: URL
BACKEND_API_URL=http://localhost:5000/api

# ------------------------------------------
# Vector Database
# ------------------------------------------
# Description: Path to store ChromaDB data
# Required: Optional (Defaults to "./chroma_data")
# Format: Directory path
CHROMA_PERSIST_DIRECTORY=./chroma_data

# ------------------------------------------
# External APIs & Models (AI)
# ------------------------------------------
# Description: Provider for embeddings (e.g., huggingface, openai)
# Required: Optional (Defaults to "huggingface")
# Format: String
EMBEDDING_PROVIDER=huggingface

# Description: Model to use for embeddings
# Required: Optional (Defaults to "sentence-transformers/all-MiniLM-L6-v2")
# Format: String
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Description: OpenAI API Key (Required if using OpenAI provider)
# Required: Optional (Defaults to empty)
# Format: String
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Description: Base URL for Ollama service
# Required: Optional (Defaults to "http://localhost:11434")
# Format: URL
OLLAMA_BASE_URL=http://localhost:11434

# Description: Provider for LLMs (e.g., ollama, openai, anthropic, groq)
# Required: Optional (Defaults to "ollama")
# Format: String
LLM_PROVIDER=ollama

# Description: Model to use for LLM
# Required: Optional (Defaults to "qwen2.5:1.5b")
# Format: String
LLM_MODEL=qwen2.5:1.5b

# Description: Temperature for LLM generation
# Required: Optional (Defaults to 0.0)
# Format: Float
LLM_TEMPERATURE=0.0

# Description: Anthropic API Key (Required if using Anthropic provider)
# Required: Optional (Defaults to empty)
# Format: String
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Description: Groq API Key (Required if using Groq provider)
# Required: Optional (Defaults to empty)
# Format: String
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Description: Enable explanations generated by AI
# Required: Optional (Defaults to False)
# Format: Boolean (True/False)
ENABLE_AI_EXPLANATIONS=False

# ------------------------------------------
# Processing Configuration
# ------------------------------------------
# Description: Size of text chunks for indexing
# Required: Optional (Defaults to 1000)
# Format: Integer
CHUNK_SIZE=1000

# Description: Overlap between text chunks
# Required: Optional (Defaults to 200)
# Format: Integer
CHUNK_OVERLAP=200

# Description: Batch size for indexing operations
# Required: Optional (Defaults to 100)
# Format: Integer
BATCH_SIZE=100

# Description: List of collections to manage in vector DB
# Required: Optional (Defaults to ["properties", "ownership", "documents", "financial", "legal", "timeline", "location"])
# Format: JSON array string
COLLECTIONS=["properties", "ownership", "documents", "financial", "legal", "timeline", "location"]
